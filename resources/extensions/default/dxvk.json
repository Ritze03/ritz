{
  "Extension": {
    "Name": "DXVK",
    "Author": "Ritze",
    "Version": "1.0",
    "Description": "Tuning for DXVK (Direct3D 8/9/10/11 to Vulkan)."
  },
  "UI": {
    "Basic": [
      {
        "Name": "FPS Limit",
        "Description": "Limit the frame rate (dxvk.maxFrameRate). 0 = uncapped.",
        "Type": "integer",
        "Variable": "fps_limit",
        "Options": { "min": 0, "max": 360, "step": 1 }
      }
    ],
    "HUD": [
      {
        "Name": "HUD Elements",
        "Description": "DXVK_HUD overlay — comma-separated keys, e.g. fps,gpuload,devinfo,memory,version (or 'full').",
        "Type": "string",
        "Variable": "hud"
      }
    ],
    "Performance": [
      {
        "Name": "Graphics Pipeline Library",
        "Description": "dxvk.enableGraphicsPipelineLibrary — compile pipelines in the background to reduce shader stutter.",
        "Type": "selection",
        "Variable": "gpl",
        "Options": ["Auto", "True", "False"]
      },
      {
        "Name": "Max Frame Latency",
        "Description": "dxgi.maxFrameLatency / d3d9.maxFrameLatency — number of queued frames (0 = no override). Lower can reduce input latency.",
        "Type": "integer",
        "Variable": "max_frame_latency",
        "Options": { "min": 0, "max": 16, "step": 1 }
      }
    ],
    "Display": [
      {
        "Name": "Tear-Free",
        "Description": "dxvk.tearFree — force tearing off (mailbox) or allow it (relaxed fifo).",
        "Type": "selection",
        "Variable": "tear_free",
        "Options": ["Auto", "True", "False"]
      },
      {
        "Name": "HDR",
        "Description": "DXVK_HDR — expose HDR10 colorspace (needs a compatible game and display).",
        "Type": "toggle",
        "Variable": "hdr",
        "Default": false
      }
    ]
  },
  "ENV_VARS": [
    {
      "Name": "DXVK_CONFIG",
      "Requires": "",
      "Builder": [
        { "Requires": "fps_limit", "Type": "append", "Separator": "; ", "Value": "dxvk.maxFrameRate = {fps_limit}" },
        { "Requires": "gpl", "Type": "append", "Separator": "; ", "Value": "dxvk.enableGraphicsPipelineLibrary = {gpl}" },
        { "Requires": "max_frame_latency", "Type": "append", "Separator": "; ", "Value": "dxgi.maxFrameLatency = {max_frame_latency}; d3d9.maxFrameLatency = {max_frame_latency}" },
        { "Requires": "tear_free", "Type": "append", "Separator": "; ", "Value": "dxvk.tearFree = {tear_free}" }
      ]
    },
    {
      "Name": "DXVK_HUD",
      "Requires": "hud",
      "Builder": [{ "Requires": "hud", "Type": "set", "Value": "{hud}" }]
    },
    {
      "Name": "DXVK_HDR",
      "Requires": "hdr",
      "Builder": [{ "Requires": "hdr", "Type": "set", "Value": "1" }]
    }
  ]
}
