{
  "Extension": {
    "Name": "AMD",
    "Author": "Ritze",
    "Version": "1.0",
    "Description": "Tuning options for the AMD RADV Vulkan driver."
  },
  "UI": {
    "RADV Perftest": [
      {
        "Name": "Enable RADV Perftest",
        "Description": "Enable RADV_PERFTEST tuning.",
        "Type": "toggle",
        "Variable": "enabled",
        "Default": false
      },
      {
        "Name": "Clear Default Perftest",
        "Description": "Clear RADV_PERFTEST before applying options.",
        "Type": "toggle",
        "Variable": "clear",
        "Requires": "enabled"
      },
      {
        "Name": "NGGC (NGG Culling)",
        "Description": "Force-enable NGG culling on GPUs where it is not on by default.",
        "Type": "toggle",
        "Variable": "nggc",
        "Requires": "enabled"
      },
      {
        "Name": "SAM (Smart Access Memory)",
        "Description": "Move more driver-internal objects to VRAM (benefits resizable BAR / Smart Access Memory).",
        "Type": "toggle",
        "Variable": "sam",
        "Requires": "enabled"
      }
    ],
    "Vulkan": [
      {
        "Name": "Mesa Anti-Lag",
        "Description": "Enable the VK_LAYER_MESA_anti_lag implicit layer to reduce input latency.",
        "Type": "toggle",
        "Variable": "anti_lag",
        "Default": false
      }
    ],
    "Experimental": [
      {
        "Name": "AMD User Queue",
        "Description": "Experimental user-mode submission queue (AMD_USERQ=1).",
        "Type": "toggle",
        "Variable": "userq",
        "Default": false
      }
    ]
  },
  "ENV_VARS": [
    {
      "Name": "RADV_PERFTEST",
      "Requires": "enabled",
      "Builder": [
        { "Requires": "clear", "Type": "set", "Value": "" },
        { "Requires": "nggc", "Type": "append", "Separator": ",", "Value": "nggc" },
        { "Requires": "sam", "Type": "append", "Separator": ",", "Value": "sam" }
      ]
    },
    {
      "Name": "AMD_USERQ",
      "Requires": "userq",
      "Builder": [{ "Requires": "userq", "Type": "set", "Value": "1" }]
    },
    {
      "Name": "VK_INSTANCE_LAYERS",
      "Requires": "anti_lag",
      "Builder": [
        { "Requires": "anti_lag", "Type": "append", "Separator": ":", "Value": "VK_LAYER_MESA_anti_lag" }
      ]
    }
  ]
}
